generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String    @unique
  password        String
  productionId    Int?
  superUserStatus String    @default("Disabled")
  status          String    @default("Activated")
  avatar          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  roles           UserRole[]
  sessions        Session[]
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  status      String    @default("Activated")
  type        String    @default("Team Based Role")
  permissions Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       UserRole[]
}

model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int
  roleId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  token        String   @unique
  refreshToken String   @unique
  ip           String?
  userAgent    String?
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SmtpServer {
  id              Int       @id @default(autoincrement())
  name            String
  host            String
  port            Int       @default(25)
  encryption      String    @default("None")
  status          String    @default("Activated")
  username        String?
  password        String?
  proxyIp         String?
  proxyPort       Int?
  proxyUsername   String?
  proxyPassword   String?
  serverProviderId Int?
  expirationDate  DateTime?
  lastChecked     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ServerProvider {
  id        Int      @id @default(autoincrement())
  name      String
  status    String   @default("Activated")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MtaServer {
  id              Int       @id @default(autoincrement())
  name            String
  serverProviderId Int?
  status          String    @default("Activated")
  hostname        String?
  mainIp          String
  sshPort         Int       @default(22)
  os              String    @default("ubuntu")
  loginType       String    @default("user-pass")
  username        String    @default("root")
  password        String?
  pemFile         String?
  passphrase      String?
  ips             String?
  sshStatus       String    @default("Unknown")
  country         String?
  expirationDate  DateTime?
  lastChecked     DateTime?
  installationStatus String? @default("Not Installed")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  virtualLists    VirtualList[]
  sendProcesses   SendProcess[]
}

model Domain {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  accountName     String?
  status          String    @default("Activated")
  availability    String    @default("Available")
  expirationDate  DateTime?
  hasBrand        Boolean   @default(false)
  flag            String?
  country         String?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  records         DomainRecord[]
  mailboxes       Mailbox[]
}

model DomainRecord {
  id        Int      @id @default(autoincrement())
  domainId  Int
  type      String
  name      String
  value     String
  ttl       Int      @default(3600)
  priority  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  domain    Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
}

model DataList {
  id                  Int       @id @default(autoincrement())
  name                String
  emailCount          Int       @default(0)
  country             String?
  vertical            String?
  isp                 String?
  encryptEmails       String    @default("Disabled")
  status              String    @default("Activated")
  createdBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  autoResponderLists  AutoResponderList[]
  sendProcesses       SendProcess[]
}

model SmtpGroup {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  encryption      String    @default("None")
  status          String    @default("Activated")
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  virtualLists    VirtualList[]
  sendProcesses   SendProcess[]
}

model Proxy {
  id        Int      @id @default(autoincrement())
  ip        String
  port      Int
  username  String?
  password  String?
  type      String    @default("HTTP")
  status    String    @default("Activated")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Offer {
  id            Int      @id @default(autoincrement())
  name          String
  url           String?
  fromName      String?
  fromEmail     String?
  subject       String?
  replyTo       String?
  headers       String?
  status        String   @default("Activated")
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  suppressions  Suppression[]
  sendProcesses SendProcess[]
}

model Suppression {
  id            Int      @id @default(autoincrement())
  offerId       Int?
  name          String
  type          String   @default("Email")
  data          String?
  count         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  offer         Offer?   @relation(fields: [offerId], references: [id], onDelete: Cascade)
}

model AffiliateNetwork {
  id            Int      @id @default(autoincrement())
  name          String
  url           String?
  status        String   @default("Activated")
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AutoResponder {
  id            Int      @id @default(autoincrement())
  name          String
  fromName      String?
  fromEmail     String?
  subject       String?
  delay         Int       @default(0)
  headers       String?
  message       String?
  status        String   @default("Activated")
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lists         AutoResponderList[]
}

model AutoResponderList {
  id              Int           @id @default(autoincrement())
  autoResponderId Int
  dataListId      Int
  autoResponder   AutoResponder @relation(fields: [autoResponderId], references: [id], onDelete: Cascade)
  dataList        DataList      @relation(fields: [dataListId], references: [id], onDelete: Cascade)

  @@unique([autoResponderId, dataListId])
}

model VirtualList {
  id            Int      @id @default(autoincrement())
  name          String
  smtpGroupId   Int?
  mtaServerId   Int?
  status        String   @default("Activated")
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  smtpGroup     SmtpGroup? @relation(fields: [smtpGroupId], references: [id], onDelete: SetNull)
  mtaServer     MtaServer? @relation(fields: [mtaServerId], references: [id], onDelete: SetNull)
  sendProcesses SendProcess[]
}

model Production {
  id              Int      @id @default(autoincrement())
  name            String
  status          String   @default("Activated")
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  processes       SendProcess[]
}

model SendProcess {
  id              Int      @id @default(autoincrement())
  productionId    Int
  dataListId      Int?
  smtpGroupId     Int?
  mtaServerId     Int?
  offerId         Int?
  virtualListId   Int?
  processName     String
  subject         String?
  fromEmail       String?
  fromName        String?
  replyTo         String?
  senderScore     Int?
  throttle        Int       @default(0)
  speed           Int       @default(100)
  scheduleAt      DateTime?
  repeat          String?
  status          String    @default("Pending")
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  production      Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  dataList        DataList?  @relation(fields: [dataListId], references: [id], onDelete: SetNull)
  smtpGroup       SmtpGroup? @relation(fields: [smtpGroupId], references: [id], onDelete: SetNull)
  mtaServer       MtaServer? @relation(fields: [mtaServerId], references: [id], onDelete: SetNull)
  offer           Offer?     @relation(fields: [offerId], references: [id], onDelete: SetNull)
  virtualList     VirtualList? @relation(fields: [virtualListId], references: [id], onDelete: SetNull)
}

model GmailAccount {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  clientId        String?
  clientSecret    String?
  refreshToken    String?
  status          String   @default("Activated")
  senderScore     Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model GSuiteAccount {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  clientId        String?
  clientSecret    String?
  refreshToken    String?
  status          String   @default("Activated")
  senderScore     Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OutlookAccount {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  clientId        String?
  clientSecret    String?
  refreshToken    String?
  tenantId        String?
  status          String   @default("Activated")
  senderScore     Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CloudAccount {
  id              Int      @id @default(autoincrement())
  provider        String
  name            String
  status          String   @default("Activated")
  apiKey          String?
  apiSecret       String?
  proxyIp         String?
  proxyPort       Int?
  proxyUsername   String?
  proxyPassword   String?
  providerConfig  Json?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  instances       CloudInstance[]
}

model CloudInstance {
  id              Int       @id @default(autoincrement())
  provider        String
  cloudAccountId  Int?
  numberOfInstances Int     @default(1)
  regions         Json?
  dnsAccountId    Int?
  os              String    @default("ubuntu-22.04")
  instanceType    String?
  privateIps      Int       @default(1)
  storage         Int       @default(10)
  status          String    @default("Pending")
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  cloudAccount    CloudAccount? @relation(fields: [cloudAccountId], references: [id], onDelete: SetNull)
}

model RegistrarAccount {
  id              Int      @id @default(autoincrement())
  registrar       String
  name            String
  status          String   @default("Activated")
  apiKey          String?
  apiSecret       String?
  apiToken        String?
  username        String?
  password        String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PostmasterAccount {
  id              Int      @id @default(autoincrement())
  domain          String
  serverName      String?
  providerName    String?
  imapHost        String?
  imapPort        Int?
  smtpHost        String?
  smtpPort        Int?
  username        String?
  password        String?
  status          String   @default("Activated")
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Header {
  id        Int      @id @default(autoincrement())
  name      String
  header    String   @db.Text
  status    String   @default("Activated")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DataProvider {
  id        Int      @id @default(autoincrement())
  name      String
  status    String   @default("Activated")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Isp {
  id        Int      @id @default(autoincrement())
  name      String
  status    String   @default("Activated")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ManagementServer {
  id              Int      @id @default(autoincrement())
  name            String
  providerId      Int?
  status          String   @default("Activated")
  expirationDate  DateTime?
  hostname        String?
  mainIp          String
  sshPort         Int      @default(22)
  loginType       String   @default("user-pass")
  username        String   @default("root")
  password        String?
  passphrase      String?
  pemFile         String?
  sshStatus       String   @default("Unknown")
  lastChecked     DateTime?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Mailbox {
  id        Int      @id @default(autoincrement())
  domainId  Int
  email     String
  status    String   @default("Activated")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  domain    Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
}
