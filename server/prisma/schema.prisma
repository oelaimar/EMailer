generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  firstName       String
  lastName        String
  email           String    @unique
  password        String
  productionId    Int?
  superUserStatus String    @default("Disabled")
  status          String    @default("Activated")
  avatar          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  roles           UserRole[]
  sessions        Session[]
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  status      String    @default("Activated")
  type        String    @default("Team Based Role")
  permissions Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       UserRole[]
}

model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int
  roleId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  token        String   @unique
  refreshToken String   @unique
  ip           String?
  userAgent    String?
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SmtpServer {
  id              Int       @id @default(autoincrement())
  name            String
  host            String
  port            Int       @default(25)
  encryption      String    @default("None")
  status          String    @default("Activated")
  username        String?
  password        String?
  proxyIp         String?
  proxyPort       Int?
  proxyUsername   String?
  proxyPassword   String?
  serverProviderId Int?
  expirationDate  DateTime?
  lastChecked     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ServerProvider {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}

model MtaServer {
  id              Int       @id @default(autoincrement())
  name            String
  serverProviderId Int?
  status          String    @default("Activated")
  hostname        String?
  mainIp          String
  sshPort         Int       @default(22)
  os              String    @default("ubuntu")
  loginType       String    @default("user-pass")
  username        String    @default("root")
  password        String?
  pemFile         String?
  passphrase      String?
  ips             String?
  sshStatus       String    @default("Unknown")
  country         String?
  expirationDate  DateTime?
  lastChecked     DateTime?
  installationStatus String? @default("Not Installed")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Domain {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  accountName     String?
  status          String    @default("Activated")
  availability    String    @default("Available")
  expirationDate  DateTime?
  hasBrand        Boolean   @default(false)
  flag            String?
  country         String?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  records         DomainRecord[]
}

model DomainRecord {
  id        Int      @id @default(autoincrement())
  domainId  Int
  type      String
  name      String
  value     String
  ttl       Int      @default(3600)
  priority  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  domain    Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
}

model DataList {
  id              Int       @id @default(autoincrement())
  name            String
  emailCount      Int       @default(0)
  country         String?
  vertical        String?
  isp             String?
  encryptEmails   String    @default("Disabled")
  status          String    @default("Activated")
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model SmtpGroup {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  encryption      String    @default("None")
  status          String    @default("Activated")
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Proxy {
  id        Int      @id @default(autoincrement())
  ip        String
  port      Int
  username  String?
  password  String?
  type      String    @default("HTTP")
  status    String    @default("Activated")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
