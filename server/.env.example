# Vugex V2 - Server Environment Variables
# Copy this file to .env and update the values for production.

# Server port
PORT=3000

# Database connection (update host/password for production)
# When using docker-compose, the host is "mysql" (the service name)
DATABASE_URL="mysql://root:CHANGE_ME_PASSWORD@mysql:3306/vugex_v2"

# JWT secrets - CHANGE THESE to strong random strings in production
# Generate with: openssl rand -hex 32
JWT_SECRET="CHANGE_ME_TO_A_STRONG_RANDOM_SECRET"
JWT_REFRESH_SECRET="CHANGE_ME_TO_ANOTHER_STRONG_RANDOM_SECRET"

# Token expiration
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS origin - set to your production domain
# When using docker-compose, the frontend is served by nginx on the same origin
CORS_ORIGIN="http://localhost"

# Node environment
NODE_ENV=production
